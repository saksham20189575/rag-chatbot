GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
BGE_MODEL_NAME=BAAI/bge-small-en-v1.5

# Groq quota guardrails (llama-3.3-70b-versatile free tier — tune if limits change)
GROQ_MAX_TOKENS=150
GROQ_REQUEST_TIMEOUT=25
GROQ_RPM_LIMIT=25
GROQ_TPM_LIMIT=10000
GROQ_RPD_LIMIT=900
GROQ_TPD_LIMIT=90000

# API request rate limit (defaults to GROQ_RPM_LIMIT)
# API_RPM_LIMIT=25

# Streamlit UI (Phase 5)
CHAT_API_URL=http://localhost:8000
